# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Phase 0 local data store (server/local-store.ts) — real writes made
# through the app before a Supabase project exists. Never commit real
# client/financial data or uploaded receipts.
/.local-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
