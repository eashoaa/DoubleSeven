NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Brevo (email + SMS reminders) — see src/lib/integrations/brevo.ts.
# Everything on the Overdue page works once BREVO_API_KEY is set; no other
# code changes needed.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
BREVO_SMS_SENDER=

# Shared secret for /api/cron/send-overdue-reminders — required once that
# route is wired to an external scheduler (Vercel Cron, Supabase pg_cron,
# cron-job.org, etc.) so it can't be triggered by anyone who finds the URL.
CRON_SECRET=
